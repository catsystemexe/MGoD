{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "strict": true,
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/game",
    "src/engine",
    "src/graphics",
    "src/main.ts",
    "src/**/*.d.ts",
    "vite-env.d.ts",
    "src/vite-env.d.ts"
  ],
  "exclude": [
    "**/*.smoke.ts",
    "src/engine/_legacy",
    "src/debug"
  ]
}