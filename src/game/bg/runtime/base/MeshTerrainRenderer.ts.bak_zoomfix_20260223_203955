    bumpSharp: 1.8,

    // near/far amplitude shaping
    depthAmpPow: 1.6,

    // amplitude depth remap (near-flat / far-mountains)
    ampDepthNear: 0.35,
    ampDepthFar:  1.35,
    ampDepthBias: 0.55,
    ampDepthPow:  1.6,

    // bump depth remap (less bumps near, more far)
    bumpDepthNear: 0.25,
    bumpDepthFar:  1.10,
    bumpDepthBias: 0.55,
    bumpDepthPow:  1.6,

    bumpOctaves: 5,
    bumpRot: 0.9,
    timeMul: 0.0,

    // projection
    tilt: 1.25,
    persp: 1.35,
