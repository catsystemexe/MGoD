    gridZ: 80,
  };

  init(gl: WebGL2RenderingContext, w: number, h: number): void {
    this.gl = gl;

    const VS = `#version 300 es
precision highp float;

layout(location=0) in vec2 aXZ; // x in [-1..1], z in [0..1] (depth)

uniform float uTime;
uniform float uTimeMul;
uniform vec2  uScroll;

// layer1
uniform float uAmp;
uniform float uFreq;
uniform float uSpeed;

// layer2
uniform float uAmp2;
uniform float uFreq2;
uniform float uSpeed2;

// warp + shaping
uniform float uWarpAmp;
uniform float uWarpFreq;
uniform float uWarpSpeed;
uniform float uDepthAmpPow;

// amplitude depth remap
uniform float uAmpDepthNear;
uniform float uAmpDepthFar;
uniform float uAmpDepthBias;
uniform float uAmpDepthPow;

// bump depth remap
uniform float uBumpDepthNear;
uniform float uBumpDepthFar;
uniform float uBumpDepthBias;
uniform float uBumpDepthPow;
uniform float uBumpOctaves;
uniform float uBumpRot;


// bump detail
uniform float uBumpAmp;
uniform float uBumpFreq;
uniform float uBumpSpeed;
uniform float uBumpSharp;

// projection
uniform float uTilt;
uniform float uPersp;
uniform float uXSpan;
uniform float uNearDrop;
uniform float uYShift;
uniform float uChunkOffset;
uniform float uChunkOffsetZ;

float waveLayer(float x, float z, float t, float amp, float freq) {
  float a = sin((x*1.30 + t*0.70) * freq);
  float b = sin((z*1.70 + t*0.40) * (freq*0.80));
  float c = sin((x*0.90 + z*0.60 + t*0.25) * (freq*0.55));
  return (a*0.55 + b*0.35 + c*0.25) * amp;
}

// Cheap domain warp (no noise): produces organic "flow" instead of wallpaper sinus.
vec2 domainWarp(float x, float z, float t) {
  float tf = t * uWarpSpeed;

  // Two coupled oscillators (x<->z) so it doesn't look axis-aligned.
  float wx = sin((z * 1.25 + tf) * uWarpFreq + sin((x * 0.70 - tf) * (uWarpFreq * 0.7)));
  float wz = sin((x * 1.10 - tf) * uWarpFreq + sin((z * 0.85 + tf) * (uWarpFreq * 0.6)));

  // Keep warp mostly horizontal; a bit in z so patterns breathe in depth.
  return vec2(wx, wz) * uWarpAmp;
}

// --- tiny value noise (no texture) for local "peaks" ---
float hash12(vec2 p) {
  float h = dot(p, vec2(127.1, 311.7));
  return fract(sin(h) * 43758.5453123);
}

float noise2(vec2 p) {
  vec2 i = floor(p);
  vec2 f = fract(p);
  // smoothstep
  f = f * f * (3.0 - 2.0 * f);

  float a = hash12(i + vec2(0.0, 0.0));
  float b = hash12(i + vec2(1.0, 0.0));
  float c = hash12(i + vec2(0.0, 1.0));
  float d = hash12(i + vec2(1.0, 1.0));

  float u = mix(a, b, f.x);
  float v = mix(c, d, f.x);
  return mix(u, v, f.y); // 0..1
}

mat2 rot2(float a) {
  float s = sin(a), c = cos(a);
  return mat2(c, -s, s, c);
}

// FBM over value-noise. Returns ~0..1
float fbm2(vec2 p, int oct, float ang) {
  // clamp octaves 1..5
  oct = clamp(oct, 1, 5);

  float sum = 0.0;
  float amp = 0.5;

  mat2 r = rot2(ang);

  // fixed max loop, break based on oct
  for (int i = 0; i < 5; i++) {
    if (i >= oct) break;

    sum += noise2(p) * amp;

    // rotate + scale to kill axis bands
    p = (r * p) * 2.02 + vec2(17.3, 9.2);
    amp *= 0.5;
  }

  // normalization (approx for up to 5 octaves: 0.5+0.25+... = <1)
  return sum;
}

void main() {
  float t = uTime * uTimeMul;
  
  // base time
  float t1 = t * uSpeed;
  float t2 = t * uSpeed2;

// Lokální X z gridu (-1..1 přepočtené přes xSpan)
float localX = (aXZ.x * uXSpan);

// chunk world pos
float worldX = localX + uChunkOffset;

// Kamera
float cameraX = uScroll.x;

// View-space pro projekci
float viewX = worldX - cameraX;

// Sampling běží ve WORLD prostoru
float x = worldX;

 // --- WORLD Z --------------------------------------------------

float localZ = aXZ.y;
float worldZ = localZ + uChunkOffsetZ;

// !!! uScroll.y je v px, Z je 0..1 => musí být škálováno
// TODO: později uděláme uniform (uScrollYMul). Teď hardcode stabilní default:
const float SCROLL_Y_TO_Z = 0.002;      // dolaď; typicky 0.001..0.004
float cameraZ = uScroll.y * SCROLL_Y_TO_Z;

// view-space depth (jen pro projekci)
float viewZ = worldZ - cameraZ;

// weights pro near/far mají být z lokálního gridu (stabilní)
float zBase = localZ;

// projekční depth má být stabilní a nezáporný (jinak denom “překlápí” svět)
float zProj   = clamp(viewZ, 0.0, 1.2);  // perspektiva

// sampling depth má běžet ve WORLD prostoru (kamera nemá měnit vlny)
float zSample = worldZ;


  // ✅ z=0 NEAR, z=1 FAR
  float nearW = 1.0 - zBase;  // 1 near → 0 far
  float farW  = zBase;        // 0 near → 1 far

  // Domain warp coordinates (use projection depth so the >1 tail still animates coherently)
  vec2 w = domainWarp(x, zSample, t);
float xw = x + w.x;
float zw = zSample + (w.y * 0.35);

  // FBM phase jitter to kill long sinus bands (uses same bump controls)
  int oct = int(floor(uBumpOctaves + 0.5));
  float phase = (fbm2(vec2(xw, zw) * (uBumpFreq * 0.08) + vec2(12.7, 3.1), oct, uBumpRot) - 0.5) * 2.0;

  // Spatial domain warp (coords, not time) to break long sinus bands
  // Uses FBM so it stays coherent but not axis-aligned.
  vec2 xz = vec2(xw, zw);
  mat2 rr = rot2(uBumpRot * 0.5 + 0.7);
  xz = rr * xz;

  float dw1 = (fbm2(xz * (uBumpFreq * 0.045) + vec2(5.1, 8.3), oct, uBumpRot + 1.3) - 0.5) * 2.0;
  float dw2 = (fbm2(xz * (uBumpFreq * 0.030) + vec2(11.7, 2.9), oct, uBumpRot + 2.1) - 0.5) * 2.0;

  float xwf = xz.x + dw1 * 0.22;
  float zwf = xz.y + dw2 * 0.14;


  // Two-layer height
  float y1 = waveLayer(xw, zw, t1 + phase * 0.35, uAmp,  uFreq);
  float y2 = waveLayer(xw * 1.07, zw * 0.93, t2 + phase * 0.55, uAmp2, uFreq2);

  float y = y1 + y2;

  // Local bumps: break "stripy bands" into smaller peaks.
  // Use warped coords so bumps flow with the big deformation.
  float tb = t * uBumpSpeed;
  vec2 bp = vec2(xwf, zwf) * uBumpFreq + vec2(tb * 0.35, -tb * 0.22);

  // base noise 0..1 -> -1..1
  float bn = fbm2(bp, oct, uBumpRot) * 2.0 - 1.0;

  // sharpen (preserve sign): higher sharp => more pointy peaks
  float bAbs = abs(bn);
  float bPow = pow(bAbs, max(0.05, uBumpSharp));
  float bSigned = (bn < 0.0) ? -bPow : bPow;

  // bump amount (optionally calmer FAR, stronger NEAR)
  float wzB = pow(clamp((zBase - uBumpDepthBias) + 0.5, 0.0, 1.0), max(0.01, uBumpDepthPow));
  float bumpShape = mix(uBumpDepthNear, uBumpDepthFar, wzB);
  y += bSigned * uBumpAmp * bumpShape;

  // Depth amplitude shaping: FAR calmer, NEAR wilder.
  float wzA = pow(clamp((zBase - uAmpDepthBias) + 0.5, 0.0, 1.0), max(0.01, uAmpDepthPow));
  float ampRemap = mix(uAmpDepthNear, uAmpDepthFar, wzA);
  float legacy = mix(0.35, 1.0, pow(clamp(nearW, 0.0, 1.0), max(0.01, uDepthAmpPow)));
  y *= ampRemap * legacy;

  // Perspective projection uses zProj
float denom = 0.80 + zProj * uPersp;

// Kamera: projekce používá pouze lokální grid,
// sampling používá worldX (oddělení prostoru)
float px = viewX / denom;

  // 1) TILT: pushes NEAR down (apply in world space before projection)
  float yTilt = -(nearW * uTilt);

  float py = (y + yTilt) / denom;

  // 2) FAR lift: affects FAR only (apply AFTER projection -> intuitive)
  const float FAR_LIFT = 0.55;   // + = horizon UP
  py += farW * FAR_LIFT;

  // 3) NEAR drop: affects NEAR only (apply AFTER projection -> intuitive)
  py -= nearW * uNearDrop;

  // Global composition shift
  vec2 clip = vec2(px, py + uYShift);
  gl_Position = vec4(clip, 0.0, 1.0);
}
`;

    const FS = `#version 300 es
precision highp float;
out vec4 o;
uniform float uAlpha;
void main() {
  o = vec4(1.0, 1.0, 1.0, uAlpha);
}
`;

    const vs = compile(gl, gl.VERTEX_SHADER, VS);
    const fs = compile(gl, gl.FRAGMENT_SHADER, FS);
    const prog = link(gl, vs, fs);

    gl.deleteShader(vs);
    gl.deleteShader(fs);

    this.prog = prog;

    this.uTime = gl.getUniformLocation(prog, "uTime");
    this.uTimeMul = gl.getUniformLocation(prog, "uTimeMul");
    this.uScroll = gl.getUniformLocation(prog, "uScroll");
    
    this.uAmp = gl.getUniformLocation(prog, "uAmp");
    this.uFreq = gl.getUniformLocation(prog, "uFreq");
    this.uSpeed = gl.getUniformLocation(prog, "uSpeed");

    this.uAmp2 = gl.getUniformLocation(prog, "uAmp2");
    this.uFreq2 = gl.getUniformLocation(prog, "uFreq2");
    this.uSpeed2 = gl.getUniformLocation(prog, "uSpeed2");

    this.uWarpAmp = gl.getUniformLocation(prog, "uWarpAmp");
    this.uWarpFreq = gl.getUniformLocation(prog, "uWarpFreq");
    this.uWarpSpeed = gl.getUniformLocation(prog, "uWarpSpeed");
    this.uDepthAmpPow = gl.getUniformLocation(prog, "uDepthAmpPow");

    this.uBumpAmp = gl.getUniformLocation(prog, "uBumpAmp");
    this.uBumpFreq = gl.getUniformLocation(prog, "uBumpFreq");
    this.uBumpSpeed = gl.getUniformLocation(prog, "uBumpSpeed");
    this.uBumpSharp = gl.getUniformLocation(prog, "uBumpSharp");
    this.uBumpOctaves = gl.getUniformLocation(prog, "uBumpOctaves");
    this.uBumpRot = gl.getUniformLocation(prog, "uBumpRot");
    
      // depth remap (amp)
      this.uAmpDepthNear = gl.getUniformLocation(prog, "uAmpDepthNear");
      this.uAmpDepthFar  = gl.getUniformLocation(prog, "uAmpDepthFar");
      this.uAmpDepthBias = gl.getUniformLocation(prog, "uAmpDepthBias");
      this.uAmpDepthPow  = gl.getUniformLocation(prog, "uAmpDepthPow");

      // depth remap (bumps)
      this.uBumpDepthNear = gl.getUniformLocation(prog, "uBumpDepthNear");
      this.uBumpDepthFar  = gl.getUniformLocation(prog, "uBumpDepthFar");
      this.uBumpDepthBias = gl.getUniformLocation(prog, "uBumpDepthBias");
      this.uBumpDepthPow  = gl.getUniformLocation(prog, "uBumpDepthPow");

    this.uTilt = gl.getUniformLocation(prog, "uTilt");
    this.uXSpan = gl.getUniformLocation(prog, "uXSpan");
    this.uPersp = gl.getUniformLocation(prog, "uPersp");
    this.uAlpha = gl.getUniformLocation(prog, "uAlpha");
    this.uNearDrop = gl.getUniformLocation(prog, "uNearDrop");
    this.uYShift = gl.getUniformLocation(prog, "uYShift");
    this.uChunkOffset = gl.getUniformLocation(prog, "uChunkOffset");
    this.uChunkOffsetZ = gl.getUniformLocation(prog, "uChunkOffsetZ");
    
    // geometry buffer (lines grid)
    this.vao = gl.createVertexArray();
    this.vbo = gl.createBuffer();
    if (!this.vao || !this.vbo) throw new Error("MeshTerrainRenderer: VAO/VBO create failed");

    gl.bindVertexArray(this.vao);
    gl.bindBuffer(gl.ARRAY_BUFFER, this.vbo);

    // build once; can be rebuilt by calling rebuild()
    const data = this.buildGrid(this.mesh.gridX, this.mesh.gridZ);
    this.vertCount = (data.length / 2) | 0;
    gl.bufferData(gl.ARRAY_BUFFER, data, gl.STATIC_DRAW);

    gl.enableVertexAttribArray(0);
    gl.vertexAttribPointer(0, 2, gl.FLOAT, false, 2 * 4, 0);

    gl.bindVertexArray(null);
    gl.bindBuffer(gl.ARRAY_BUFFER, null);
  }

  private buildGrid(gridX: number, gridZ: number): Float32Array {
    const gx = Math.max(8, Math.min(400, Math.floor(gridX)));
    const gz = Math.max(8, Math.min(300, Math.floor(gridZ)));

    const vCount = gx * (gz * 2) + gz * (gx * 2);
    const out = new Float32Array(vCount * 2);

    let k = 0;

    // vertical lines (constant x, varying z)
    for (let ix = 0; ix < gx; ix++) {
      const x = -1 + (2 * ix) / (gx - 1);
      for (let iz = 0; iz < gz; iz++) {
        const z = iz / (gz - 1);
        if (iz < gz - 1) {
          const z2 = (iz + 1) / (gz - 1);
          out[k++] = x;  out[k++] = z;
          out[k++] = x;  out[k++] = z2;
        }
      }
    }

    // horizontal lines (constant z, varying x)
    for (let iz = 0; iz < gz; iz++) {
      const z = iz / (gz - 1);
      for (let ix = 0; ix < gx; ix++) {
        const x = -1 + (2 * ix) / (gx - 1);
        if (ix < gx - 1) {
          const x2 = -1 + (2 * (ix + 1)) / (gx - 1);
          out[k++] = x;  out[k++] = z;
          out[k++] = x2; out[k++] = z;
        }
      }
    }

    if (k !== out.length) return out.slice(0, k);
    return out;
  }

  rebuild(args: any): void {
    if (!this.gl || !this.vbo) return;

    const mp: MeshParams | undefined = args?.mesh;
    if (mp && typeof mp === "object") {
      if (Number.isFinite(mp.amp as any)) this.mesh.amp = Number(mp.amp);
      if (Number.isFinite(mp.freq as any)) this.mesh.freq = Number(mp.freq);
      if (Number.isFinite(mp.speed as any)) this.mesh.speed = Number(mp.speed);

      if (Number.isFinite(mp.amp2 as any)) this.mesh.amp2 = Number(mp.amp2);
      if (Number.isFinite(mp.freq2 as any)) this.mesh.freq2 = Number(mp.freq2);
      if (Number.isFinite(mp.speed2 as any)) this.mesh.speed2 = Number(mp.speed2);

      if (Number.isFinite(mp.warpAmp as any)) this.mesh.warpAmp = Number(mp.warpAmp);
      if (Number.isFinite(mp.warpFreq as any)) this.mesh.warpFreq = Number(mp.warpFreq);
      if (Number.isFinite(mp.warpSpeed as any)) this.mesh.warpSpeed = Number(mp.warpSpeed);

      if (Number.isFinite(mp.bumpAmp as any)) this.mesh.bumpAmp = Number(mp.bumpAmp);
      if (Number.isFinite(mp.bumpFreq as any)) this.mesh.bumpFreq = Number(mp.bumpFreq);
      if (Number.isFinite(mp.bumpSpeed as any)) this.mesh.bumpSpeed = Number(mp.bumpSpeed);
      if (Number.isFinite(mp.bumpSharp as any)) this.mesh.bumpSharp = Number(mp.bumpSharp);

      if (Number.isFinite(mp.depthAmpPow as any)) this.mesh.depthAmpPow = Number(mp.depthAmpPow);

      if (Number.isFinite((mp as any).ampDepthNear as any)) this.mesh.ampDepthNear = Number((mp as any).ampDepthNear);
      if (Number.isFinite((mp as any).ampDepthFar  as any)) this.mesh.ampDepthFar  = Number((mp as any).ampDepthFar);
      if (Number.isFinite((mp as any).ampDepthBias as any)) this.mesh.ampDepthBias = Number((mp as any).ampDepthBias);
      if (Number.isFinite((mp as any).ampDepthPow  as any)) this.mesh.ampDepthPow  = Number((mp as any).ampDepthPow);

      if (Number.isFinite((mp as any).bumpDepthNear as any)) this.mesh.bumpDepthNear = Number((mp as any).bumpDepthNear);
      if (Number.isFinite((mp as any).bumpDepthFar  as any)) this.mesh.bumpDepthFar  = Number((mp as any).bumpDepthFar);
      if (Number.isFinite((mp as any).bumpDepthBias as any)) this.mesh.bumpDepthBias = Number((mp as any).bumpDepthBias);
      if (Number.isFinite((mp as any).bumpDepthPow  as any)) this.mesh.bumpDepthPow  = Number((mp as any).bumpDepthPow);


      if (Number.isFinite((mp as any).bumpOctaves as any)) this.mesh.bumpOctaves = Math.floor(Number((mp as any).bumpOctaves));
      if (Number.isFinite((mp as any).bumpRot as any)) this.mesh.bumpRot = Number((mp as any).bumpRot);
      if (Number.isFinite((mp as any).timeMul as any)) this.mesh.timeMul = Number((mp as any).timeMul);
      
      if (Number.isFinite(mp.tilt as any)) this.mesh.tilt = Number(mp.tilt);
      if (Number.isFinite(mp.persp as any)) this.mesh.persp = Number(mp.persp);
      if (Number.isFinite(mp.xSpan as any)) this.mesh.xSpan = Number(mp.xSpan);

      if (Number.isFinite(mp.lineAlpha as any)) this.mesh.lineAlpha = Number(mp.lineAlpha);
      if (Number.isFinite(mp.gridX as any)) this.mesh.gridX = Math.floor(Number(mp.gridX));
      if (Number.isFinite(mp.gridZ as any)) this.mesh.gridZ = Math.floor(Number(mp.gridZ));
    }

    const gl = this.gl;
    const data = this.buildGrid(this.mesh.gridX, this.mesh.gridZ);
    this.vertCount = (data.length / 2) | 0;
    gl.bindBuffer(gl.ARRAY_BUFFER, this.vbo);
    gl.bufferData(gl.ARRAY_BUFFER, data, gl.STATIC_DRAW);
    gl.bindBuffer(gl.ARRAY_BUFFER, null);
  }

  setUniforms(params: any, time: number, scroll: any, _mouse: any): void {
    this.time = Number(time ?? 0);
    this.scrollX = Number(scroll?.x ?? 0);
    this.scrollY = Number(scroll?.y ?? 0);

    const mp: MeshParams = params?.mesh ?? params?.common?.mesh ?? {};
    if (mp && typeof mp === "object") {
      if (mp.amp !== undefined) this.mesh.amp = Number(mp.amp) || this.mesh.amp;
      if (mp.freq !== undefined) this.mesh.freq = Number(mp.freq) || this.mesh.freq;
      if (mp.speed !== undefined) this.mesh.speed = Number(mp.speed) || this.mesh.speed;

      if (mp.amp2 !== undefined) this.mesh.amp2 = Number(mp.amp2) || this.mesh.amp2;
      if (mp.freq2 !== undefined) this.mesh.freq2 = Number(mp.freq2) || this.mesh.freq2;
      if (mp.speed2 !== undefined) this.mesh.speed2 = Number(mp.speed2) || this.mesh.speed2;

      if (mp.warpAmp !== undefined) this.mesh.warpAmp = Number(mp.warpAmp) || this.mesh.warpAmp;
      if (mp.warpFreq !== undefined) this.mesh.warpFreq = Number(mp.warpFreq) || this.mesh.warpFreq;
      if (mp.warpSpeed !== undefined) this.mesh.warpSpeed = Number(mp.warpSpeed) || this.mesh.warpSpeed;

      if (mp.bumpAmp !== undefined) this.mesh.bumpAmp = Number(mp.bumpAmp) || this.mesh.bumpAmp;
      if (mp.bumpFreq !== undefined) this.mesh.bumpFreq = Number(mp.bumpFreq) || this.mesh.bumpFreq;
      if (mp.bumpSpeed !== undefined) this.mesh.bumpSpeed = Number(mp.bumpSpeed) || this.mesh.bumpSpeed;
      if (mp.bumpSharp !== undefined) this.mesh.bumpSharp = Number(mp.bumpSharp) || this.mesh.bumpSharp;

      if ((mp as any).bumpOctaves !== undefined) this.mesh.bumpOctaves = Math.floor(Number((mp as any).bumpOctaves)) || this.mesh.bumpOctaves;
      if ((mp as any).bumpRot !== undefined) this.mesh.bumpRot = Number((mp as any).bumpRot) || this.mesh.bumpRot;
      if ((mp as any).timeMul !== undefined) this.mesh.timeMul = Number((mp as any).timeMul);
      
      if (mp.depthAmpPow !== undefined) this.mesh.depthAmpPow = Number(mp.depthAmpPow) || this.mesh.depthAmpPow;

      if ((mp as any).ampDepthNear !== undefined) this.mesh.ampDepthNear = Number((mp as any).ampDepthNear) || this.mesh.ampDepthNear;
      if ((mp as any).ampDepthFar  !== undefined) this.mesh.ampDepthFar  = Number((mp as any).ampDepthFar)  || this.mesh.ampDepthFar;
      if ((mp as any).ampDepthBias !== undefined) this.mesh.ampDepthBias = Number((mp as any).ampDepthBias) || this.mesh.ampDepthBias;
      if ((mp as any).ampDepthPow  !== undefined) this.mesh.ampDepthPow  = Number((mp as any).ampDepthPow)  || this.mesh.ampDepthPow;

      if ((mp as any).bumpDepthNear !== undefined) this.mesh.bumpDepthNear = Number((mp as any).bumpDepthNear) || this.mesh.bumpDepthNear;
      if ((mp as any).bumpDepthFar  !== undefined) this.mesh.bumpDepthFar  = Number((mp as any).bumpDepthFar)  || this.mesh.bumpDepthFar;
      if ((mp as any).bumpDepthBias !== undefined) this.mesh.bumpDepthBias = Number((mp as any).bumpDepthBias) || this.mesh.bumpDepthBias;
      if ((mp as any).bumpDepthPow  !== undefined) this.mesh.bumpDepthPow  = Number((mp as any).bumpDepthPow)  || this.mesh.bumpDepthPow;

      if (mp.tilt !== undefined) this.mesh.tilt = Number(mp.tilt) || this.mesh.tilt;
      if (mp.persp !== undefined) this.mesh.persp = Number(mp.persp) || this.mesh.persp;
      if (mp.xSpan !== undefined) this.mesh.xSpan = Number(mp.xSpan) || this.mesh.xSpan;
      if ((mp as any).nearDrop !== undefined) this.mesh.nearDrop = Number((mp as any).nearDrop) || this.mesh.nearDrop;
      if ((mp as any).yShift !== undefined) this.mesh.yShift = Number((mp as any).yShift) || this.mesh.yShift;

      if (mp.lineAlpha !== undefined) this.mesh.lineAlpha = Number(mp.lineAlpha) || this.mesh.lineAlpha;

      
      if (Number.isFinite((mp as any).bumpOctaves as any)) this.mesh.bumpOctaves = Math.floor(Number((mp as any).bumpOctaves));
      if (Number.isFinite((mp as any).bumpRot as any)) this.mesh.bumpRot = Number((mp as any).bumpRot);

      if ((mp as any).bumpOctaves !== undefined) this.mesh.bumpOctaves = Math.floor(Number((mp as any).bumpOctaves)) || this.mesh.bumpOctaves;
      if ((mp as any).bumpRot !== undefined) this.mesh.bumpRot = Number((mp as any).bumpRot) || this.mesh.bumpRot;


    }
  }

  draw(): void {
    const gl = this.gl;
    if (!gl || !this.prog || !this.vao) return;

    gl.useProgram(this.prog);
    gl.bindVertexArray(this.vao);

    gl.uniform1f(this.uTime, this.time);
    gl.uniform1f(this.uTimeMul, this.mesh.timeMul);
    gl.uniform2f(this.uScroll, this.scrollX, this.scrollY);

    // layer1
    gl.uniform1f(this.uAmp, this.mesh.amp);
    gl.uniform1f(this.uFreq, this.mesh.freq);
    gl.uniform1f(this.uSpeed, this.mesh.speed);

    // layer2
    gl.uniform1f(this.uAmp2, this.mesh.amp2);
    gl.uniform1f(this.uFreq2, this.mesh.freq2);
    gl.uniform1f(this.uSpeed2, this.mesh.speed2);

    // warp + shaping
    gl.uniform1f(this.uWarpAmp, this.mesh.warpAmp);
    gl.uniform1f(this.uWarpFreq, this.mesh.warpFreq);
    gl.uniform1f(this.uWarpSpeed, this.mesh.warpSpeed);
    gl.uniform1f(this.uDepthAmpPow, this.mesh.depthAmpPow);

    // bump detail
    gl.uniform1f(this.uBumpAmp, this.mesh.bumpAmp);
    gl.uniform1f(this.uBumpFreq, this.mesh.bumpFreq);
    gl.uniform1f(this.uBumpSpeed, this.mesh.bumpSpeed);
    gl.uniform1f(this.uBumpSharp, this.mesh.bumpSharp);

      // depth remap (amp)
      gl.uniform1f(this.uAmpDepthNear, this.mesh.ampDepthNear);
      gl.uniform1f(this.uAmpDepthFar,  this.mesh.ampDepthFar);
      gl.uniform1f(this.uAmpDepthBias, this.mesh.ampDepthBias);
      gl.uniform1f(this.uAmpDepthPow,  this.mesh.ampDepthPow);

      // depth remap (bumps)
      gl.uniform1f(this.uBumpDepthNear, this.mesh.bumpDepthNear);
      gl.uniform1f(this.uBumpDepthFar,  this.mesh.bumpDepthFar);
      gl.uniform1f(this.uBumpDepthBias, this.mesh.bumpDepthBias);
      gl.uniform1f(this.uBumpDepthPow,  this.mesh.bumpDepthPow);

    // projection
    gl.uniform1f(this.uTilt, this.mesh.tilt);
    gl.uniform1f(this.uPersp, this.mesh.persp);
    gl.uniform1f(this.uXSpan, this.mesh.xSpan);
    gl.uniform1f(this.uNearDrop, this.mesh.nearDrop);
    gl.uniform1f(this.uYShift, this.mesh.yShift);

    // render
    gl.uniform1f(this.uAlpha, this.mesh.lineAlpha);
    gl.uniform1f(this.uBumpOctaves, this.mesh.bumpOctaves);
    gl.uniform1f(this.uBumpRot, this.mesh.bumpRot);

    
    const n = this.vertCount | 0;
    if (n <= 0) return;

      // ----- HORIZONTAL -----
      const CHUNK_WIDTH = this.mesh.xSpan * 2;
      const cameraX = this.scrollX;
      const chunkIndexX = Math.floor(cameraX / CHUNK_WIDTH);

      // ----- VERTICAL (scrollY is in px, gridZ is 0..1) -----
      const CHUNK_HEIGHT = 1.0; // z in [0..1] per grid page

      // px -> zUnits (temporary constant; later make it a uniform/preset param)
      const SCROLL_Y_TO_Z = 0.002; // tune 0.001..0.004
      const cameraZ = this.scrollY * SCROLL_Y_TO_Z;

      const chunkIndexZ = Math.floor(cameraZ / CHUNK_HEIGHT);
      const offsetZ = chunkIndexZ * CHUNK_HEIGHT;

      // ✅ render ONLY 1 Z chunk (no overlap)
      gl.uniform1f(this.uChunkOffsetZ!, offsetZ);

      // render 3 X chunks
      for (let i = -1; i <= 1; i++) {
        const idxX = chunkIndexX + i;
        const offsetX = idxX * CHUNK_WIDTH;

        gl.uniform1f(this.uChunkOffset!, offsetX);
        gl.drawArrays(gl.LINES, 0, n);
      }
    

    gl.bindVertexArray(null);
  }

  dispose(): void {
    const gl = this.gl;
    if (!gl) return;

    try { if (this.vbo) gl.deleteBuffer(this.vbo); } catch {}
    try { if (this.vao) gl.deleteVertexArray(this.vao); } catch {}
    try { if (this.prog) gl.deleteProgram(this.prog); } catch {}

    this.vbo = null;
    this.vao = null;
    this.prog = null;
    this.gl = null;
  }
}
