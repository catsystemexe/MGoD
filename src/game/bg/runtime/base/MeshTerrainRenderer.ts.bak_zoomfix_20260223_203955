import type { BaseRenderer } from "./BaseRenderer";

type MeshParams = {
  amp?: number;        // base height amplitude (layer1)
  freq?: number;       // base wave frequency (layer1)
  speed?: number;      // base time speed (layer1)

  amp2?: number;       // layer2 amplitude
  freq2?: number;      // layer2 frequency
  speed2?: number;     // layer2 time speed

  warpAmp?: number;    // domain warp amplitude (organics)
  warpFreq?: number;   // domain warp frequency
  warpSpeed?: number;  // domain warp time speed

  bumpAmp?: number;    // local bump detail amplitude (adds "peaks")
  bumpFreq?: number;   // local bump density
  bumpSpeed?: number;  // local bump time speed
  bumpSharp?: number;  // local bump sharpness (higher => spikier)
  bumpOctaves?: number; // fbm octaves for bumps (1..5)
  bumpRot?: number;     // domain rotation in radians (0..pi)

  timeMul?: number;     // 1=normal, 0=freeze deformation (scroll still runs)

  depthAmpPow?: number;

  ampDepthNear?: number;  // amplitude multiplier at NEAR
  ampDepthFar?: number;   // amplitude multiplier at FAR
  ampDepthBias?: number;  // depth pivot (0=near..1=far)
  ampDepthPow?: number;   // depth curve power (higher = sharper)

  bumpDepthNear?: number; // bump multiplier at NEAR
  bumpDepthFar?: number;  // bump multiplier at FAR
  bumpDepthBias?: number; // bump depth pivot
  bumpDepthPow?: number;  // bump depth curve power


  tilt?: number;       // how much terrain goes down with depth (NEAR down)
  persp?: number;      // perspective strength
  xSpan?: number;      // horizontal span multiplier for x

  nearDrop?: number;   // extra drop for NEAR edge (bigger => more visible near)
  yShift?: number;     // global Y shift in clip space

  lineAlpha?: number;  // line alpha
  gridX?: number;      // number of vertical lines
  gridZ?: number;      // number of horizontal lines
};

function compile(gl: WebGL2RenderingContext, type: number, src: string): WebGLShader {
  const sh = gl.createShader(type);
  if (!sh) throw new Error("MeshTerrainRenderer: createShader failed");
  gl.shaderSource(sh, src);
  gl.compileShader(sh);
  if (!gl.getShaderParameter(sh, gl.COMPILE_STATUS)) {
    const log = gl.getShaderInfoLog(sh) || "";
    gl.deleteShader(sh);
    throw new Error("MeshTerrainRenderer: shader compile failed: " + log);
  }
  return sh;
}

function link(gl: WebGL2RenderingContext, vs: WebGLShader, fs: WebGLShader): WebGLProgram {
  const p = gl.createProgram();
  if (!p) throw new Error("MeshTerrainRenderer: createProgram failed");
  gl.attachShader(p, vs);
  gl.attachShader(p, fs);
  gl.linkProgram(p);
  if (!gl.getProgramParameter(p, gl.LINK_STATUS)) {
    const log = gl.getProgramInfoLog(p) || "";
    gl.deleteProgram(p);
    throw new Error("MeshTerrainRenderer: program link failed: " + log);
  }
  return p;
}

export class MeshTerrainRenderer implements BaseRenderer {
