{
  "fsm.turret": {
    "initial": "enter",
    "states": {
      "enter": {
        "movementPresetId": "straight.basic",
        "transitions": [
          {
            "when": {
              "kind": "xLessThan",
              "x": 900
            },
            "goto": "attack"
          }
        ]
      },
      "attack": {
        "movementPresetId": "none.basic",
        "attackProfileId": "spread_basic",
        "transitions": [
          {
            "when": {
              "kind": "timeInState",
              "seconds": 8
            },
            "goto": "retreat"
          }
        ]
      },
      "retreat": {
        "movementPresetId": "straight.basic",
        "transitions": [
          {
            "when": {
              "kind": "offscreen",
              "side": "left"
            },
            "goto": "despawn"
          }
        ]
      },
      "despawn": {}
    }
  },
  "fsm.hover": {
    "initial": "enter",
    "states": {
      "enter": {
        "movementPresetId": "straight.basic",
        "transitions": [
          {
            "when": {
              "kind": "xLessThan",
              "x": 760
            },
            "goto": "hover"
          }
        ]
      },
      "hover": {
        "movementPresetId": "none.basic",
        "attackProfileId": "spread_basic",
        "transitions": [
          {
            "when": {
              "kind": "timeInState",
              "seconds": 8
            },
            "goto": "retreat"
          }
        ]
      },
      "retreat": {
        "movementPresetId": "straight.basic",
        "transitions": [
          {
            "when": {
              "kind": "offscreen",
              "side": "left"
            },
            "goto": "despawn"
          }
        ]
      },
      "despawn": {}
    }
  },
  "fsm.charge": {
    "initial": "enter",
    "states": {
      "enter": {
        "movementPresetId": "straight.basic",
        "transitions": [
          {
            "when": {
              "kind": "xLessThan",
              "x": 900
            },
            "goto": "charge"
          }
        ]
      },
      "charge": {
        "movementPresetId": "straight.charge",
        "transitions": [
          {
            "when": {
              "kind": "timeInState",
              "seconds": 2
            },
            "goto": "despawn"
          }
        ]
      },
      "despawn": {}
    }
  }
}
