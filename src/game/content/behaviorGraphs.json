  "fsm.turret": {
    "initial": "enter",
    "states": {
      "enter": {
        "movementPresetId": "straight.basic",
        "transitions": [
          {
            "when": {
              "kind": "xLessThan",
              "x": 700
            },
            "goto": "attack"
          }
        ]
      },
      "attack": {
        "movementPresetId": "none.hold",
        "attackProfileId": "spread_test_slow",
        "transitions": [
          {
            "when": {
              "kind": "timeInState",
              "seconds": 5
            },
            "goto": "retreat"
          }
        ]
      },
      "retreat": {
        "movementPresetId": "straight.charge",
        "transitions": [
          {
            "when": {
              "kind": "offscreen",
              "side": "left"
            },
            "goto": "despawn"
          }
        ]
      },
      "despawn": {}
    }
  },
